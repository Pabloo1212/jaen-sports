{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/((?!assets/|backend/|ai/|.*\\.html$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
